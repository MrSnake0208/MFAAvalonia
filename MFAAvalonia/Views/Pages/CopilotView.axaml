<UserControl
    x:Class="MFAAvalonia.Views.Pages.CopilotView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MFAAvalonia.ViewModels.Pages"
    xmlns:helper="clr-namespace:MFAAvalonia.Helper"
    xmlns:pages="clr-namespace:MFAAvalonia.ViewModels.Pages"
    xmlns:markup="https://codewf.com"
    xmlns:suki="https://github.com/kikipoulet/SukiUI"
    xmlns:fluent="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
    xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
    xmlns:maa="clr-namespace:MFAAvalonia.Extensions.MaaFW"
    xmlns:converters="clr-namespace:MFAAvalonia.Helper.Converters"
    xmlns:calcBinding="clr-namespace:CalcBinding;assembly=CalcBindingAva"
    xmlns:interaction="using:Avalonia.Xaml.Interactivity"
    xmlns:behaviors="using:Avalonia.Xaml.Interactions.Core"
    xmlns:binding="clr-namespace:MaaFramework.Binding;assembly=MaaFramework.Binding"
    xmlns:ex="clr-namespace:MFAAvalonia.Extensions"
    xmlns:controls="clr-namespace:MFAAvalonia.Views.UserControls"
    d:DesignWidth="1200"
    d:DesignHeight="800"
    x:DataType="vm:CopilotViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:CopilotViewModel />
    </Design.DataContext>

    <!-- 三列布局，复刻主页结构 -->
    <Grid ClipToBounds="False" Margin="0,0,0,0" x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding Column1Width, Source={x:Static helper:Instances.TaskQueueViewModel}}" MinWidth="200" />
            <ColumnDefinition Width="15" />
            <ColumnDefinition Width="{Binding Column2Width, Source={x:Static helper:Instances.TaskQueueViewModel}}" MinWidth="200" />
            <ColumnDefinition Width="15" />
            <ColumnDefinition Width="{Binding Column3Width, Source={x:Static helper:Instances.TaskQueueViewModel}}" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <!-- 左侧列：导入 + 作业展示 + 开始任务按钮 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 导入区（替换运行环境） -->
            <suki:GlassCard Grid.Row="0" Margin="15,15,0,0">
                <suki:GroupBox>
                    <suki:GroupBox.Header>
                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SukiLowText}"
                                   Margin="2,0,0,0" Text="导入" />
                    </suki:GroupBox.Header>
                    <StackPanel Spacing="6" Margin="8,4,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Width="130" Watermark="maay://&lt;id&gt;" Text="{Binding SecretCode, Mode=TwoWay}"/>
                            <Button Classes="Basic" Click="OnOpenShareSite">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <fluent:FluentIcon Icon="Globe" IconSize="Size16" IconVariant="Regular" />
                                    <TextBlock Text=" 作业站" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="Basic" Click="OnImportMysteryCode" PointerPressed="OnImportMysteryCodePointerPressed">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <fluent:FluentIcon Icon="Clipboard" IconSize="Size16" IconVariant="Regular" />
                                    <TextBlock Text="使用神秘代码" />
                                </StackPanel>
                            </Button>
                            <Button Classes="Basic" Click="OnImportLocalJson">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <fluent:FluentIcon Icon="FolderOpen" IconSize="Size16" IconVariant="Regular" />
                                    <TextBlock Text="本地导入" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock FontSize="14" Foreground="{DynamicResource SukiDisabledText}"
                                   Text=" 左键点击自动粘贴+导入单份作业📒" TextWrapping="Wrap"/>
                        <TextBlock FontSize="14" Foreground="{DynamicResource SukiDisabledText}"
                                   Text=" 右键点击粘贴导入作业集📚" TextWrapping="Wrap"/>
                    </StackPanel>
                </suki:GroupBox>
            </suki:GlassCard>

            <!-- 作业展示 + 开始任务（放入同一容器） -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <suki:GlassCard Grid.Row="0" Margin="15,5,0,25">
                    <suki:GroupBox>
                        <suki:GroupBox.Header>
                            <Grid>
                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SukiLowText}"
                                           HorizontalAlignment="Left" Margin="2,0,0,0" Text="作业列表" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Classes="Basic Round" Height="16" Padding="0" Margin="7,0,0,0"
                                        ToolTip.Tip="打开作业文件夹" Click="OnOpenCacheDir">
                                    <fluent:FluentIcon Icon="Folder" IconSize="Size16" IconVariant="Regular" />
                                </Button>
                                <Button Classes="Basic Round" Height="16" Padding="0" Margin="7,0,0,0"
                                        ToolTip.Tip="刷新作业列表" Click="OnRefresh">
                                    <fluent:FluentIcon Icon="ArrowClockwise" IconSize="Size16" IconVariant="Regular" />
                                </Button>
                                <Button Classes="Basic Round" Height="16" Padding="0" Margin="7,0,8,0"
                                        ToolTip.Tip="卸载当前激活的文件" Click="OnUnloadActiveJob">
                                    <fluent:FluentIcon Icon="FolderArrowLeft" IconSize="Size16" IconVariant="Regular" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </suki:GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                            <TextBlock Text="当前激活："/>
                            <TextBlock Text="{Binding ActiveJob}" Foreground="{DynamicResource SukiPrimaryColor}"/>
                        </StackPanel>
                        <TreeView Grid.Row="1"
                                  x:Name="CopilotTree"
                                  Classes="Fluent"
                                  ItemsSource="{Binding FileTree}"
                                  MinHeight="220"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="FocusAdorner" Value="{x:Null}" />
                                    <Setter Property="ContextMenu">
                                        <ContextMenu>
                                            <MenuItem Header="删除" Click="OnDeleteSelectedJobs" />
                                        </ContextMenu>
                                    </Setter>
                                </Style>
                                <Style Selector="TreeViewItem:pointerover /template/ Border#SelectionBorder">
                                    <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor7}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor7}" />
                                </Style>
                                <Style Selector="TreeViewItem:pressed /template/ Border#SelectionBorder">
                                    <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor15}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor15}" />
                                </Style>
                                <Style Selector="TreeViewItem:selected /template/ Border#SelectionBorder">
                                    <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor20}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor20}" />
                                </Style>
                                <Style Selector="TreeViewItem:selected:pointerover /template/ Border#SelectionBorder">
                                    <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor25}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor25}" />
                                </Style>
                                <Style Selector="TreeViewItem:focus /template/ Border#SelectionBorder">
                                    <Setter Property="BorderBrush" Value="{DynamicResource SukiPrimaryColor20}" />
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="vm:CopilotTreeItem" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,2">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                    </suki:GroupBox>
                </suki:GlassCard>

                <!-- 开始任务按钮，保持原位与行为 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="15 0 0  7" Orientation="Horizontal">
                <StackPanel.Resources>
                    <markup:IfConditionConverter x:Key="StatusConditionConverter">
                        <markup:IfConditionConverter.True>
                            <TextBlock Text="{markup:I18n {x:Static helper:LangKeys.StopTask}}" />
                        </markup:IfConditionConverter.True>
                        <markup:IfConditionConverter.False>
                            <TextBlock Text="{markup:I18n {x:Static helper:LangKeys.StartTask}}" />
                        </markup:IfConditionConverter.False>
                    </markup:IfConditionConverter>
                </StackPanel.Resources>
                <Button Classes="Flat Rounded" Command="{Binding ToggleCopilotTaskCommand}"
                        Content="{Binding IsRunning, Source={x:Static helper:Instances.RootViewModel}, Converter={StaticResource StatusConditionConverter}}"
                        FontWeight="DemiBold" Height="40" Width="150" />
            </StackPanel>
            </Grid>
        </Grid>

        <!-- 分隔条1 -->
        <GridSplitter Grid.Column="1"
                      Background="Transparent"
                      Margin="0"
                      Width="15"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" DragCompleted="GridSplitter_DragCompleted"
                      x:Name="Splitter1">
            <GridSplitter.Template>
                <ControlTemplate>
                    <Border Background="Transparent"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"
                            Cursor="SizeWestEast">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="3">
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
            <interaction:Interaction.Behaviors>
                <behaviors:EventTriggerBehavior EventName="DragStarted">
                    <behaviors:InvokeCommandAction Command="{Binding GridSplitterDragStartedCommand, Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                                   CommandParameter="Splitter1" />
                </behaviors:EventTriggerBehavior>
                <behaviors:EventTriggerBehavior EventName="DragCompleted">
                    <behaviors:InvokeCommandAction Command="{Binding GridSplitterDragCompletedCommand, Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                                   CommandParameter="Splitter1" />
                </behaviors:EventTriggerBehavior>
            </interaction:Interaction.Behaviors>
        </GridSplitter>

        <!-- 中间列：任务设置 + 任务说明（占位） -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <suki:GlassCard Grid.Row="0" Margin="0,15,0,5" x:Name="Row1">
                <suki:GlassCard.Resources>
                    <suki:IfConditionConverter x:Key="IfConditionConverter">
                        <suki:IfConditionConverter.True>
                            <Thickness>0,1,0,10</Thickness>
                        </suki:IfConditionConverter.True>
                        <suki:IfConditionConverter.False>
                            <Thickness>0,10,0,10</Thickness>
                        </suki:IfConditionConverter.False>
                    </suki:IfConditionConverter>
                </suki:GlassCard.Resources>
                <suki:GroupBox SeparatorMargin="{Binding ShowSettings, Source={x:Static helper:Instances.TaskQueueViewModel}, Converter={StaticResource IfConditionConverter}}">
                    <suki:GroupBox.Header>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SukiLowText}"
                                       HorizontalAlignment="Left"
                                       Margin="2,0,0,0"
                                       Text="{markup:I18n {x:Static helper:LangKeys.TaskSettings}}"
                                       VerticalAlignment="Top" />
                            <StackPanel Margin="2 0 0 5" Orientation="Horizontal" HorizontalAlignment="Right"
                                        DockPanel.Dock="Right" IsVisible="{Binding ShowSettings, Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                        Spacing="8">
                                <RadioButton FontSize="11" FontWeight="Bold" Classes="Inner"
                                             IsChecked="{Binding IsCommon, Source={x:Static helper:Instances.TaskQueueViewModel}}" GroupName="SettingB">
                                    <TextBlock Text="{markup:I18n {x:Static helper:LangKeys.CommonSetting}}"></TextBlock>
                                </RadioButton>
                                <RadioButton FontSize="11" FontWeight="Bold" Classes="Inner" GroupName="SettingB"
                                             IsChecked="{calcBinding:Binding '!IsCommon', Source={x:Static helper:Instances.TaskQueueViewModel}}">
                                    <TextBlock Text="{markup:I18n {x:Static helper:LangKeys.AdvancedSetting}}"></TextBlock>
                                </RadioButton>
                            </StackPanel>
                        </DockPanel>
                    </suki:GroupBox.Header>
                    <ScrollViewer HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel IsVisible="{calcBinding:Binding 'IsCommon', Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                        x:Name="CopilotCommonOptionSettings" Orientation="Vertical" />
                            <StackPanel IsVisible="{calcBinding:Binding '!IsCommon', Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                        x:Name="CopilotAdvancedOptionSettings" Orientation="Vertical" />
                        </Grid>
                    </ScrollViewer>
                </suki:GroupBox>
            </suki:GlassCard>
            <!-- 垂直滑块：在任务设置与任务说明之间可调整高度比例 -->
            <GridSplitter Grid.Row="1" Height="8" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <GridSplitter.Template>
                    <ControlTemplate>
                        <Border Background="Transparent" Cursor="SizeNorthSouth">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                <Rectangle Width="24" Height="2" Fill="{DynamicResource SukiControlBorderBrush}"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <suki:GlassCard Grid.Row="2" Margin="0,8,15,25">
                <suki:GroupBox>
                    <suki:GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SukiLowText}"
                                       Margin="2,0,0,0"
                                       Text="{markup:I18n {x:Static helper:LangKeys.TaskDescription}}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button
                                    Classes="Basic Round"
                                    Command="{Binding LikeCommand}"
                                    IsEnabled="{Binding CanLike}"
                                    Margin="3,0,3,0"
                                    Padding="0"
                                    ToolTip.Tip="点赞">
                                    <TextBlock Text="👍"/>
                                </Button>
                                <Button
                                    Classes="Basic Round"
                                    Command="{Binding OpenJobPageCommand}"
                                    IsEnabled="{Binding HasSelection}"
                                    Margin="3,0,3,0"
                                    Padding="0"
                                    ToolTip.Tip="打开作业页">
                                    <TextBlock Text="🔗"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </suki:GroupBox.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="2,2,8,2">
                        <mdxaml:MarkdownScrollViewer Margin="10,0,10,0" x:Name="CopilotIntroduction">
                            <mdxaml:MarkdownScrollViewer.Styles>
                                <StyleInclude Source="avares://MFAAvalonia/Assets/Style/MdXamlDocStyle.axaml" />
                            </mdxaml:MarkdownScrollViewer.Styles>
                        </mdxaml:MarkdownScrollViewer>
                    </ScrollViewer>
                </suki:GroupBox>
            </suki:GlassCard>
        </Grid>

        <!-- 分隔条2 -->
        <GridSplitter Grid.Column="3"
                      Background="Transparent" DragCompleted="GridSplitter_DragCompleted"
                      Margin="0"
                      Width="15"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      x:Name="Splitter2">
            <GridSplitter.Template>
                <ControlTemplate>
                    <Border Background="Transparent"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"
                            Cursor="SizeWestEast">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="3">
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SukiControlBorderBrush}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
            <interaction:Interaction.Behaviors>
                <behaviors:EventTriggerBehavior EventName="DragStarted">
                    <behaviors:InvokeCommandAction Command="{Binding GridSplitterDragStartedCommand, Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                                   CommandParameter="Splitter2" />
                </behaviors:EventTriggerBehavior>
                <behaviors:EventTriggerBehavior EventName="DragCompleted">
                    <behaviors:InvokeCommandAction Command="{Binding GridSplitterDragCompletedCommand, Source={x:Static helper:Instances.TaskQueueViewModel}}"
                                                   CommandParameter="Splitter2" />
                </behaviors:EventTriggerBehavior>
            </interaction:Interaction.Behaviors>
        </GridSplitter>
        <!-- 右侧列：连接 + 日志（原样复用） -->
        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <suki:GlassCard Grid.Row="0" Margin="0,15,15,8">
                <suki:GroupBox DataContext="{x:Static helper:Instances.TaskQueueViewModel}"
                               x:DataType="pages:TaskQueueViewModel">
                    <suki:GroupBox.Header>
                        <Grid>
                            <TextBlock FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SukiLowText}"
                                       HorizontalAlignment="Left"
                                       Margin="2,0,0,0"
                                       Text="{markup:I18n {x:Static helper:LangKeys.Connection}}"
                                       VerticalAlignment="Center" />

                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <StackPanel.Resources>
                                    <markup:IfConditionConverter x:Key="ConnectedConditionConverter">
                                        <markup:IfConditionConverter.True>
                                            <Path Data="{StaticResource ConnectedGeometry}"
                                                  Fill="LimeGreen"
                                                  Height="11"
                                                  Margin="3,2,4,0"
                                                  Stretch="Uniform"
                                                  ToolTip.Tip="{markup:I18n {x:Static helper:LangKeys.Connected}}" />
                                        </markup:IfConditionConverter.True>
                                        <markup:IfConditionConverter.False>
                                            <Path Data="{StaticResource UnconnectedGeometry}"
                                                  Fill="Red"
                                                  Height="16"
                                                  Margin="3,3,4,0"
                                                  Stretch="Uniform"
                                                  ToolTip.Tip="{markup:I18n {x:Static helper:LangKeys.Unconnected}}"
                                                  VerticalAlignment="Center" />
                                        </markup:IfConditionConverter.False>
                                    </markup:IfConditionConverter>
                                </StackPanel.Resources>
                                <Button Classes="Basic Round" ClipToBounds="False"
                                        Command="{Binding CustomAdbCommand}"
                                        IsEnabled="{Binding Idle, Source={x:Static helper:Instances.RootViewModel}}"
                                        IsVisible="{calcBinding:Binding 'CurrentController == maa:MaaControllerTypes.Adb'}"
                                        Margin="3,0,2,0"
                                        Padding="0"
                                        ToolTip.Tip="{markup:I18n {x:Static helper:LangKeys.Custom}}">
                                    <fluent:FluentIcon Height="18"
                                                       Icon="DesktopEdit"
                                                       IconSize="Size16"
                                                       IconVariant="Regular" />
                                </Button>
                                <Button Classes="Basic Round" ClipToBounds="False"
                                        Command="{Binding RefreshCommand}"
                                        IsEnabled="{Binding Idle, Source={x:Static helper:Instances.RootViewModel}}"
                                        Margin="3,0,3,0"
                                        Padding="0"
                                        ToolTip.Tip="{markup:I18n {x:Static helper:LangKeys.TooltipRefresh}}"
                                        VerticalAlignment="Center">
                                    <fluent:FluentIcon Height="18"
                                                       Icon="ArrowSync"
                                                       IconSize="Size16"
                                                       IconVariant="Regular" />
                                </Button>
                                <ContentControl
                                    Content="{Binding IsConnected, Converter={StaticResource ConnectedConditionConverter}, Source={x:Static helper:Instances.TaskQueueViewModel}}" />
                            </StackPanel>
                        </Grid>
                    </suki:GroupBox.Header>
                    <Grid x:Name="ConnectionGrid"
                          HorizontalAlignment="Stretch">
                        <!-- 控制器类型选择 -->
                        <RadioButton x:Name="AdbRadioButton"
                                     Classes="GigaChips"
                                     FontSize="12"
                                     GroupName="Controller"
                                     IsChecked="{Binding CurrentController, Converter={converters:UniversalEqualityConverter}, ConverterParameter={x:Static maa:MaaControllerTypes.Adb}, Mode=TwoWay}"
                                     IsVisible="{calcBinding:Binding 'ShouldShow != 1'}"
                                     IsEnabled="{calcBinding:Binding '!LockController and Idle',
                        &#xA;                                                                                    Source={x:Static helper:Instances.RootViewModel}}"
                                     Margin="0,0,8,0"
                                     MinWidth="110">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <controls:DisplayIcon IconSource="{Binding AdbIcon}"
                                                      IconSize="24"
                                                      IsVisible="{Binding HasAdbIcon}"
                                                      VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Adb}" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="Win32RadioButton"
                                     Classes="GigaChips"
                                     FontSize="12"
                                     GroupName="Controller"
                                     IsChecked="{Binding CurrentController, Converter={converters:UniversalEqualityConverter}, ConverterParameter={x:Static maa:MaaControllerTypes.Win32}, Mode=TwoWay}"
                                     IsVisible="{calcBinding:Binding 'ShouldShow != 2'}"
                                     IsEnabled="{calcBinding:Binding '!LockController and Idle',
                        &#xA;                                                                                    Source={x:Static helper:Instances.RootViewModel}}"
                                     Margin="0,0,8,0"
                                     MinWidth="110">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <controls:DisplayIcon IconSource="{Binding Win32Icon}"
                                                      IconSize="24"
                                                      IsVisible="{Binding HasWin32Icon}"
                                                      VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Win32}" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <!-- 设备选择器 -->
                        <Grid x:Name="DeviceSelectorPanel"
                              HorizontalAlignment="Stretch"
                              MinWidth="300">
                            <TextBlock x:Name="DeviceSelectorLabel"
                                       FontSize="12"
                                       Foreground="{DynamicResource SukiLowText}"
                                       Text="{markup:I18n {x:Static helper:LangKeys.CurrentController}}"
                                       VerticalAlignment="Center"
                                       Margin="0,2,8,0" />
                            <ComboBox x:Name="DeviceComboBox"
                                      ex:ComboBoxExtensions.DisableNavigationOnLostFocus="True"
                                      Classes="LimitWidth"
                                      IsEnabled="{Binding Idle, Source={x:Static helper:Instances.RootViewModel}}"
                                      ItemsSource="{Binding Devices}"
                                      MinWidth="100"
                                      HorizontalAlignment="Stretch"
                                      SelectedValue="{Binding CurrentDevice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ToolTip.Tip>
                                    <TextBlock
                                        Text="{Binding CurrentDevice, Converter={converters:DeviceDisplayConverter}}" />
                                </ToolTip.Tip>
                                <ComboBox.DataTemplates>
                                    <DataTemplate DataType="binding:AdbDeviceInfo">
                                        <TextBlock HorizontalAlignment="Left"
                                                   Text="{Binding Converter={converters:DeviceDisplayConverter}}" />
                                    </DataTemplate>
                                    <DataTemplate DataType="binding:DesktopWindowInfo">
                                        <TextBlock HorizontalAlignment="Left"
                                                   Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.DataTemplates>
                            </ComboBox>
                        </Grid>
                    </Grid>
                </suki:GroupBox>
            </suki:GlassCard>
            <suki:GlassCard Grid.Row="1" Margin="0,8,15,25">
                <suki:GroupBox>
                    <suki:GroupBox.Header>
                        <Grid>

                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{DynamicResource SukiLowText}"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0"
                                Text="{markup:I18n {x:Static helper:LangKeys.LogRecord}}"
                                VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button
                                    Classes="Basic Round"
                                    Command="{Binding ExportCommand}"
                                    Height="17"
                                    IsEnabled="{Binding Idle, Source={x:Static helper:Instances.RootViewModel}}"
                                    Margin="3,0,3,0"
                                    Padding="0"

                                    ToolTip.Tip="{markup:I18n {x:Static helper:LangKeys.ExportLog}}"
                                    VerticalAlignment="Center">

                                    <fluent:FluentIcon
                                        Height="18"
                                        Icon="ArrowExport"
                                        IconSize="Size16"
                                        IconVariant="Regular" />
                                </Button>
                                <Button
                                    Classes="Basic Round"
                                    Command="{Binding ClearCommand}"
                                    Height="17"
                                    IsEnabled="{Binding Idle, Source={x:Static helper:Instances.RootViewModel}}"
                                    Margin="3,0,3,0"
                                    Padding="0"

                                    ToolTip.Tip="{markup:I18n {x:Static helper:LangKeys.ButtonClear}}"
                                    VerticalAlignment="Center">

                                    <fluent:FluentIcon
                                        Height="18"
                                        Icon="ArrowSync"
                                        IconSize="Size16"
                                        IconVariant="Regular" />
                                </Button>
                            </StackPanel>
                        </Grid>

                    </suki:GroupBox.Header>
                    <ScrollViewer
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        ClipToBounds="False"
                        Margin="15,8,10,5"
                        VerticalAlignment="Top"
                        VerticalContentAlignment="Top"
                        ex:ScrollViewerExtensions.AutoScroll="True"
                        ex:ScrollViewerExtensions.PanningMode="VerticalOnly">
                        <ItemsControl ItemsSource="{Binding Path=LogItemViewModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource SukiDisabledText}"
                                            Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            Margin="0,5,2,0"
                                            MinWidth="55"
                                            Text="{Binding Time}"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Stretch" />
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="{Binding Weight}"
                                            Foreground="{Binding Color}"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,5" TextWrapping="WrapWithOverflow"
                                            Text="{Binding Content}"
                                            VerticalAlignment="Stretch" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </suki:GroupBox>
            </suki:GlassCard>
        </Grid>
    </Grid>
</UserControl>
